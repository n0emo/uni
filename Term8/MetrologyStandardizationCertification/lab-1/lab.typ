    [$A, B$], [$A<B$], [$A=B$], [$A>B$], [$A<B$], [$A=B$], [$A>B$],
    [$A>B$],  [x],     [x],     [В],     [Н],     [Н],     [В],
    [$A=B$],  [Н],     [Н],     [В],     [Н],     [Н],     [В],
    [$A=B$],  [Н],     [В],     [Н],     [Н],     [В],     [Н],
    [$A=B$],  [В],     [Н],     [Н],     [В],     [Н],     [Н],
    [$A<B$],  [x],     [x],     [x],     [В],     [Н],     [Н],

  ),
) <К564ИП2-truth>

